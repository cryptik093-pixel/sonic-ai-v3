###############################################
# Sonic AI V3 — Shared Environment
###############################################
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=info

###############################################
# API / Backend
###############################################
API_HOST=0.0.0.0
API_PORT=8000

# Switchable DB engine: mssql / postgres
DB_ENGINE=postgres

# Postgres (default local dev)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sonic_ai

# MS-SQL (for production or hybrid mode)
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong!Passw0rd
MSSQL_DB=sonic_ai

###############################################
# Redis (Queues, Caching, Rate Limits)
###############################################
REDIS_URL=redis://localhost:6379/0

###############################################
# Storage (S3 / MinIO)
###############################################
STORAGE_DRIVER=s3

# Local MinIO (recommended for dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sonic-ai
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false

# Local fallback
UPLOAD_STORAGE_PATH=./storage/uploads

###############################################
# Supabase Auth
###############################################
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_JWT_AUDIENCE=authenticated

###############################################
# JWT / Security
###############################################
JWT_SECRET=replace-me
JWT_EXPIRES_IN=1d

###############################################
# Frontend (Next.js)
###############################################
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me

###############################################
# Agents (Studio Agent / Producer Agent)
###############################################
AGENT_MODE=local
AGENT_API_KEY=replace-me

###############################################
# Audio / DSP
################################
