root = true

###############################################
# Global Defaults
###############################################
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

###############################################
# Python (Backend, Pipelines, Agents)
###############################################
[*.py]
indent_size = 4
max_line_length = 100

###############################################
# TypeScript / JavaScript (Frontend + Agents)
###############################################
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2
quote_type = single

###############################################
# JSON / YAML / TOML
###############################################
[*.{json,yml,yaml,toml}]
indent_size = 2

###############################################
# Markdown
###############################################
[*.md]
trim_trailing_whitespace = false
indent_size = 2

###############################################
# Shell / PowerShell Scripts
###############################################
[*.{sh,bash,zsh}]
indent_size = 2

[*.ps1]
indent_size = 2

###############################################
# Config / Env Files
###############################################
[*.env]
indent_style = space
indent_size = 2

###############################################
# Ignore Minified Files
###############################################
[*.min.{js,css}]
indent_style = ignore
